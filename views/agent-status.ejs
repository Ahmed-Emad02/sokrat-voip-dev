<%
const words = {
    en: {
        title: "Agent", subtitle: "Status Analytics", desc: "Real-time Agent Availability and Historical Telemetry",
        startTime: "Start Window Time", endTime: "End Window Time", btn: "Compile Analytics Models",
        thExt: "Extension", thStatus: "Status", thStart: "Start Time", thEnd: "End Time", thDur: "Duration",
        noData: "No agent status telemetry recorded inside this timeframe window.",
        totalLogs: "Total Status Logs:", footerRight: "Records Filtered:",
        statusAvailable: "Available", statusOffline: "Offline", statusOnBreak: "On Break", statusInMeeting: "In Meeting", statusLunch: "Lunch"
    },
    ar: {
        title: "حالة", subtitle: "تحليلات الموظفين", desc: "التوفر الفعلي للموظفين والسجلات التاريخية للحالة",
        startTime: "بداية النطاق الزمني", endTime: "نهاية النطاق الزمني", btn: "تجميع النماذج التحليلية",
        thExt: "التحويلة", thStatus: "الحالة", thStart: "وقت البداية", thEnd: "وقت النهاية", thDur: "المدة",
        noData: "لم يتم تسجيل بيانات حالة للموظفين ضمن هذا النطاق الزمني.",
        totalLogs: "إجمالي سجلات الحالة:", footerRight: "السجلات المفلترة:",
        statusAvailable: "متاح", statusOffline: "غير متصل", statusOnBreak: "في استراحة", statusInMeeting: "في اجتماع", statusLunch: "في استراحة غداء"
    }
};
const t = words[currentLang];
const isRtl = currentLang === 'ar';

function formatDuration(seconds) {
    if (!seconds && seconds !== 0) return '-';
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = seconds % 60;
    if (h > 0) return `${h}h ${m}m ${s}s`;
    if (m > 0) return `${m}m ${s}s`;
    return `${s}s`;
}

function getStatusColor(status) {
    switch (status) {
        case 'Available': return 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30';
        case 'Offline': return 'bg-slate-500/20 text-slate-400 border-slate-500/30';
        case 'On Break': return 'bg-amber-500/20 text-amber-400 border-amber-500/30';
        case 'In Meeting': return 'bg-purple-500/20 text-purple-400 border-purple-500/30';
        case 'Lunch': return 'bg-rose-500/20 text-rose-400 border-rose-500/30';
        default: return 'bg-gray-500/20 text-gray-400 border-gray-500/30';
    }
}
%>
<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= isRtl ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enterprise Analytics - Agent Status</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { background-color: #1A0B2E; font-family: 'Cairo', sans-serif; }
        .panel-surface { background-color: #2E113C; border: 1px solid #4A154B; }
        .accent-orange { color: #FF8700; }
        .font-vibrant-display { font-weight: 900; letter-spacing: -0.01em; }
    </style>
</head>
<body class="bg-[#1A0B2E] text-slate-100 flex min-h-screen m-0 p-0">
    <%- include('sidebar') %>
    <div class="flex-1 p-8 relative">
        <div class="absolute top-6 <%= isRtl ? 'left-8' : 'right-8' %> z-50">
            <select onchange="location.href=window.location.pathname + '?lang=' + this.value" class="bg-[#2E113C] text-white border border-purple-900 rounded-xl px-4 py-2 text-sm font-bold shadow-2xl focus:outline-none focus:border-[#FF8700] cursor-pointer">
                <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English 🇬🇧</option>
                <option value="ar" <%= currentLang === 'ar' ? 'selected' : '' %>>العربية 🇪🇬</option>
            </select>
        </div>
        
        <div class="mb-6">
            <h2 class="text-3xl font-vibrant-display text-white tracking-tight"><%= t.title %> <span class="accent-orange"><%= t.subtitle %></span></h2>
            <p class="text-xs text-purple-400 font-bold tracking-widest uppercase mt-1"><%= t.desc %></p>
        </div>

        <!-- Aggregated Totals Cards -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
            <% const statusList = ['Available', 'Offline', 'On Break', 'In Meeting', 'Lunch']; %>
            <% statusList.forEach(status => { %>
                <div class="panel-surface p-4 rounded-2xl shadow-xl border-l-4 <%= status === 'Available' ? 'border-l-emerald-500' : status === 'Offline' ? 'border-l-slate-500' : status === 'On Break' ? 'border-l-amber-500' : status === 'In Meeting' ? 'border-l-purple-500' : 'border-l-rose-500' %> flex flex-col items-center justify-center">
                    <span class="text-xs font-black uppercase text-purple-300 tracking-wider mb-2"><%= t['status' + status.replace(' ', '')] || status %></span>
                    <span class="text-xl font-bold text-white"><%= formatDuration(totals[status] || 0) %></span>
                </div>
            <% }); %>
        </div>

        <form action="/agent-status" method="GET" class="panel-surface p-5 rounded-2xl mb-8 grid grid-cols-1 md:grid-cols-4 gap-4 items-end shadow-2xl">
            <input type="hidden" name="lang" value="<%= currentLang %>">
            <div>
                <label class="block text-xs font-black uppercase text-purple-300 mb-2 tracking-wider"><%= t.startTime %></label>
                <input type="datetime-local" name="startDate" value="<%= moment(filters.startDate).format('YYYY-MM-DDTHH:mm') %>" class="w-full bg-[#1A0B2E] border border-purple-900 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-[#FF8700]">
            </div>
            <div>
                <label class="block text-xs font-black uppercase text-purple-300 mb-2 tracking-wider"><%= t.endTime %></label>
                <input type="datetime-local" name="endDate" value="<%= moment(filters.endDate).format('YYYY-MM-DDTHH:mm') %>" class="w-full bg-[#1A0B2E] border border-purple-900 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-[#FF8700]">
            </div>
            <div>
                <label class="block text-xs font-black uppercase text-purple-300 mb-2 tracking-wider"><%= t.thExt %></label>
                <select name="targetExtension" class="w-full bg-[#1A0B2E] border border-purple-900 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-[#FF8700]">
                    <option value="ALL">All Agents</option>
                    <% roster.forEach(emp => { %>
                        <option value="<%= emp.extension %>" <%= filters.targetExtension == emp.extension ? 'selected' : '' %>><%= emp.extension %> - <%= emp.name %></option>
                    <% }) %>
                </select>
            </div>
            <div>
                <button type="submit" class="w-full bg-[#FF8700] hover:bg-orange-600 text-white font-black py-3 rounded-lg text-sm uppercase tracking-wider shadow-md transition cursor-pointer"><%= t.btn %></button>
            </div>
        </form>

        <div class="panel-surface rounded-2xl overflow-hidden shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-start border-collapse">
                    <thead>
                        <tr class="bg-black/40 text-purple-300 text-xs font-bold uppercase border-b border-purple-900">
                            <th class="p-4 tracking-wider text-start"><%= t.thExt %></th>
                            <th class="p-4 tracking-wider text-start"><%= t.thStatus %></th>
                            <th class="p-4 tracking-wider text-start"><%= t.thStart %></th>
                            <th class="p-4 tracking-wider text-start"><%= t.thEnd %></th>
                            <th class="p-4 tracking-wider text-start"><%= t.thDur %></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-purple-900/30 text-sm font-mono">
                        <% if(logs.length === 0) { %>
                            <tr><td colspan="5" class="p-8 text-center text-purple-400 font-sans"><%= t.noData %></td></tr>
                        <% } %>
                        <% logs.forEach(log => { %>
                            <tr class="hover:bg-purple-950/30 transition">
                                <td class="p-4 text-[#FF8700] font-bold">
                                    <%= log.extension %> 
                                    <span class="text-xs text-slate-500 font-sans block"><%= roster.find(r => r.extension == log.extension)?.name || '' %></span>
                                </td>
                                <td class="p-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border <%= getStatusColor(log.status) %>">
                                        <%= t['status' + log.status.replace(' ', '')] || log.status %>
                                    </span>
                                </td>
                                <td class="p-4 text-purple-200"><%= moment(log.start_time).format('YYYY-MM-DD HH:mm:ss') %></td>
                                <td class="p-4 text-slate-400"><%= log.end_time ? moment(log.end_time).format('YYYY-MM-DD HH:mm:ss') : 'Active' %></td>
                                <td class="p-4 text-sky-400 font-bold"><%= formatDuration(log.duration_seconds) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <div class="px-6 py-4 border-t border-purple-900 bg-black/40 flex justify-between items-center">
                <span class="text-xs font-bold uppercase tracking-widest text-purple-400"><%= t.totalLogs %></span>
                <span class="text-sm font-black text-white"><%= t.footerRight %> <span class="text-[#FF8700]"><%= logs.length %> rows</span></span>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const clockEl = document.getElementById('digitalClock');
            if(clockEl) { setInterval(() => { clockEl.textContent = new Date().toTimeString().split(' ')[0]; }, 1000); }
        });
    </script>
</body>
</html>
