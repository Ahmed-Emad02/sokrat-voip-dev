<%
const words = {
    en: {
        title: "GSM", subtitle: "Dongles",
        desc: "Real-time chan_dongle device status monitor",
        id: "ID", state: "State", number: "SIM Number", provider: "Provider",
        signal: "Signal (RSSI)", model: "Model", imei: "IMEI", imsi: "IMSI",
        available: "Available", unavailable: "Unavailable",
        restart: "Restart", restarting: "Restarting...",
        noDongles: "No dongles detected or chan_dongle not installed.",
        footerLeft: "GSM Dongle Monitor", footerRight: "Active Dongles:"
    },
    ar: {
        title: "شرائح", subtitle: "GSM",
        desc: "مراقبة حالة أجهزة GSM المتصلة",
        id: "المعرف", state: "الحالة", number: "رقم SIM", provider: "المزود",
        signal: "الإشارة (RSSI)", model: "الموديل", imei: "IMEI", imsi: "IMSI",
        available: "متاح", unavailable: "غير متاح",
        restart: "إعادة تشغيل", restarting: "جاري إعادة التشغيل...",
        noDongles: "لم يتم الكشف عن أي أجهزة GSM أو أن chan_dongle غير مثبت.",
        footerLeft: "مراقبة شرائح GSM", footerRight: "الأجهزة النشطة:"
    }
};
const t = words[currentLang];
const isRtl = currentLang === 'ar';
%>
<!DOCTYPE html>
<html lang="<%= currentLang %>" dir="<%= isRtl ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enterprise Analytics - GSM Dongles</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { background-color: #05070a; font-family: 'Cairo', sans-serif; }
        .panel-surface { background-color: #0e121a; border: 1px solid #1f2937; }
        .accent-orange { color: #06b6d4; }
        .font-vibrant-display { font-weight: 900; letter-spacing: -0.01em; }
        .dongle-card { transition: all 0.3s; }
        .dongle-card:hover { transform: translateY(-2px); }
    </style>
</head>
<body class="bg-[#05070a] text-slate-100 flex flex-col min-h-screen m-0 p-0">
    <%- include('sidebar') %>
    <div class="flex-1 p-8 relative flex flex-col min-h-screen">
        <div class="absolute top-6 <%= isRtl ? 'left-8' : 'right-8' %> z-50">
            <select onchange="location.href=window.location.pathname + '?lang=' + this.value" class="bg-[#0e121a] text-white border border-zinc-800 rounded-xl px-4 py-2 text-sm font-bold shadow-2xl focus:outline-none focus:border-[#06b6d4] cursor-pointer">
                <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English</option>
                <option value="ar" <%= currentLang === 'ar' ? 'selected' : '' %>>العربية</option>
            </select>
        </div>

        <div class="mb-6 shrink-0">
            <h2 class="text-3xl font-vibrant-display text-white tracking-tight"><%= t.title %> <span class="accent-orange"><%= t.subtitle %></span></h2>
            <p class="text-xs text-zinc-500 font-bold tracking-widest uppercase mt-1"><%= t.desc %></p>
        </div>

        <div class="flex-1 min-h-0 overflow-y-auto mb-4">
            <div id="dongleGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                <% if (dongles.length === 0) { %>
                    <div class="col-span-full text-center text-zinc-500 py-16">
                        <div class="text-6xl mb-4">📡</div>
                        <p class="text-lg font-bold"><%= t.noDongles %></p>
                    </div>
                <% } %>
                <% dongles.forEach(d => {
                    const isFree = d.state === 'Free' || d.state === 'Started';
                %>
                    <div class="dongle-card panel-surface rounded-xl p-6 border-2 <%= isFree ? 'border-emerald-500/40' : 'border-red-500/40' %> shadow-lg">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <span class="text-2xl font-mono font-black text-[#06b6d4] tracking-wider block"><%= d.id %></span>
                                <span class="text-xs font-bold text-zinc-500 block"><%= d.number %></span>
                            </div>
                            <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider <%= isFree ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30' : 'bg-red-500/20 text-red-400 border border-red-500/30' %>">
                                <%= isFree ? t.available : t.unavailable %>
                            </span>
                        </div>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between">
                                <span class="text-zinc-500"><%= t.state %>:</span>
                                <span class="text-white font-bold font-mono"><%= d.state %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-zinc-500"><%= t.provider %>:</span>
                                <span class="text-white font-mono"><%= d.provider %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-zinc-500"><%= t.signal %>:</span>
                                <span class="text-white font-mono"><%= d.rssi %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-zinc-500"><%= t.model %>:</span>
                                <span class="text-white font-mono truncate max-w-[180px]"><%= d.model %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-zinc-500">IMEI:</span>
                                <span class="text-white font-mono text-[11px]"><%= d.imei %></span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-zinc-500">IMSI:</span>
                                <span class="text-white font-mono text-[11px]"><%= d.imsi %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="panel-surface rounded-2xl px-6 py-4 bg-black/40 flex <%= isRtl ? 'flex-row-reverse' : '' %> justify-between items-center shrink-0">
            <span class="text-xs font-bold uppercase tracking-widest text-zinc-500"><%= t.footerLeft %></span>
            <span class="text-sm font-black text-white"><%= t.footerRight %> <span class="text-[#06b6d4]"><%= dongles.length %></span></span>
        </div>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const clockEl = document.getElementById('digitalClock');
            if(clockEl) { setInterval(() => { clockEl.textContent = new Date().toTimeString().split(' ')[0]; }, 1000); }
            const socket = io();
            socket.on('dongleStatus', (status) => {
                const grid = document.getElementById('dongleGrid');
                if (!grid || !status) return;
                if (status.length === 0) {
                    grid.innerHTML = '<div class="col-span-full text-center text-zinc-500 py-16"><div class="text-6xl mb-4">📡</div><p class="text-lg font-bold"><%= t.noDongles %></p></div>';
                    return;
                }
                let html = '';
                status.forEach(d => {
                    const isFree = d.state === 'Free' || d.state === 'Started';
                    html += '<div class="dongle-card panel-surface rounded-xl p-6 border-2 ' + (isFree ? 'border-emerald-500/40' : 'border-red-500/40') + ' shadow-lg">';
                    html += '<div class="flex justify-between items-start mb-4">';
                    html += '<div><span class="text-2xl font-mono font-black text-[#06b6d4] tracking-wider block">' + d.id + '</span>';
                    html += '<span class="text-xs font-bold text-zinc-500 block">' + (d.number || '') + '</span></div>';
                    html += '<span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider ' + (isFree ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30' : 'bg-red-500/20 text-red-400 border border-red-500/30') + '">' + (isFree ? '<%= t.available %>' : '<%= t.unavailable %>') + '</span>';
                    html += '</div>';
                    html += '<div class="space-y-2 text-sm">';
                    html += '<div class="flex justify-between"><span class="text-zinc-500"><%= t.state %>:</span><span class="text-white font-bold font-mono">' + d.state + '</span></div>';
                    html += '<div class="flex justify-between"><span class="text-zinc-500"><%= t.provider %>:</span><span class="text-white font-mono">' + (d.provider || '-') + '</span></div>';
                    html += '<div class="flex justify-between"><span class="text-zinc-500"><%= t.signal %>:</span><span class="text-white font-mono">' + d.rssi + '</span></div>';
                    html += '<div class="flex justify-between"><span class="text-zinc-500"><%= t.model %>:</span><span class="text-white font-mono truncate max-w-[180px]">' + (d.model || '-') + '</span></div>';
                    html += '<div class="flex justify-between"><span class="text-zinc-500">IMEI:</span><span class="text-white font-mono text-[11px]">' + (d.imei || '-') + '</span></div>';
                    html += '<div class="flex justify-between"><span class="text-zinc-500">IMSI:</span><span class="text-white font-mono text-[11px]">' + (d.imsi || '-') + '</span></div>';
                    html += '</div></div>';
                });
                grid.innerHTML = html;
            });
        });
    </script>
</body>
</html>
