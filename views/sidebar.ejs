<%
const sidebarWords = {
    en: { dashLink: "Dashboard", cdrLink: "CDR Analytics", empLink: "Employee Metrics", extLink: "Extension Statistics", opLink: "Live Operator", dongleLink: "GSM Dongles", liveClock: "System Clock" },
    ar: { dashLink: "لوحة التحكم", cdrLink: "تحليلات المكالمات", empLink: "مقاييس الموظفين", extLink: "إحصائيات التحويلة", opLink: "لوحة المراقبة المباشرة", dongleLink: "شرائح GSM", liveClock: "ساعة النظام" }
};
const sbT = sidebarWords[currentLang] || sidebarWords['en'];
const isRtl = currentLang === 'ar';
%>

<div class="w-full bg-[#080a0f] border-b border-zinc-800 flex flex-row items-center justify-between px-8 py-4 shadow-xl shrink-0 <%= isRtl ? 'flex-row-reverse' : '' %>">
    <!-- Brand Logo and Title -->
    <div class="flex items-center space-x-3 <%= isRtl ? 'space-x-reverse' : '' %>">
        <h1 class="text-lg font-black text-white tracking-wider font-vibrant-display">
            ISSABEL <span class="accent-orange">ANALYTICS</span>
        </h1>
        <div class="h-4 w-[2px] bg-zinc-800 hidden md:block"></div>
        <span class="text-xs text-zinc-500 uppercase tracking-widest hidden md:block">Telemetry Hub</span>
    </div>

    <!-- Center Navigation Links -->
    <nav class="flex items-center space-x-2 md:space-x-4 <%= isRtl ? 'space-x-reverse' : '' %>">
        <a href="/?lang=<%= currentLang %>" 
           class="flex items-center px-4 py-2 rounded-xl transition font-medium tracking-wide text-sm
           <%= currentPage === '/' ? 'bg-[#06b6d4] text-white font-bold shadow-lg shadow-[#06b6d4]/20' : 'text-zinc-400 hover:bg-zinc-900/60 hover:text-white' %>">
            <span>🏠</span>
            <span class="hidden sm:inline <%= isRtl ? 'mr-2' : 'ml-2' %>"><%= sbT.dashLink %></span>
        </a>

        <a href="/cdr?lang=<%= currentLang %>" 
           class="flex items-center px-4 py-2 rounded-xl transition font-medium tracking-wide text-sm
           <%= currentPage === '/cdr' ? 'bg-[#06b6d4] text-white font-bold shadow-lg shadow-[#06b6d4]/20' : 'text-zinc-400 hover:bg-zinc-900/60 hover:text-white' %>">
            <span>📊</span>
            <span class="hidden sm:inline <%= isRtl ? 'mr-2' : 'ml-2' %>"><%= sbT.cdrLink %></span>
        </a>

        <a href="/employees?lang=<%= currentLang %>" 
           class="flex items-center px-4 py-2 rounded-xl transition font-medium tracking-wide text-sm
           <%= currentPage === '/employees' ? 'bg-[#06b6d4] text-white font-bold shadow-lg shadow-[#06b6d4]/20' : 'text-zinc-400 hover:bg-zinc-900/60 hover:text-white' %>">
            <span>👥</span>
            <span class="hidden sm:inline <%= isRtl ? 'mr-2' : 'ml-2' %>"><%= sbT.empLink %></span>
        </a>

        <a href="/ext-stats?lang=<%= currentLang %>" 
           class="flex items-center px-4 py-2 rounded-xl transition font-medium tracking-wide text-sm
           <%= currentPage === '/ext-stats' ? 'bg-[#06b6d4] text-white font-bold shadow-lg shadow-[#06b6d4]/20' : 'text-zinc-400 hover:bg-zinc-900/60 hover:text-white' %>">
            <span>📈</span>
            <span class="hidden sm:inline <%= isRtl ? 'mr-2' : 'ml-2' %>"><%= sbT.extLink %></span>
        </a>

        <a href="/operator?lang=<%= currentLang %>" 
           class="flex items-center px-4 py-2 rounded-xl transition font-medium tracking-wide text-sm
           <%= currentPage === '/operator' ? 'bg-[#06b6d4] text-white font-bold shadow-lg shadow-[#06b6d4]/20' : 'text-zinc-400 hover:bg-zinc-900/60 hover:text-white' %>">
            <span class="relative flex h-2 w-2 items-center justify-center">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="hidden sm:inline <%= isRtl ? 'mr-2' : 'ml-2' %>"><%= sbT.opLink %></span>
        </a>

        <a href="/dongles?lang=<%= currentLang %>" 
           class="flex items-center px-4 py-2 rounded-xl transition font-medium tracking-wide text-sm
           <%= currentPage === '/dongles' ? 'bg-[#06b6d4] text-white font-bold shadow-lg shadow-[#06b6d4]/20' : 'text-zinc-400 hover:bg-zinc-900/60 hover:text-white' %>">
            <span>📶</span>
            <span class="hidden sm:inline <%= isRtl ? 'mr-2' : 'ml-2' %>"><%= sbT.dongleLink %></span>
        </a>
    </nav>

    <!-- Right Side: Clock & Lang Selector -->
    <div class="flex items-center space-x-4 <%= isRtl ? 'space-x-reverse' : '' %>">
        <!-- Digital Clock -->
        <div class="text-right hidden md:block">
            <span class="text-[9px] font-black uppercase text-zinc-500 tracking-widest block"><%= sbT.liveClock %></span>
            <div id="digitalClock" class="text-sm font-mono font-bold text-white tracking-widest">00:00:00</div>
        </div>
        
        <div class="h-4 w-[2px] bg-zinc-800 hidden md:block"></div>

        <!-- Language Selector -->
        <div>
            <select onchange="location.href=window.location.pathname + '?lang=' + this.value" class="bg-zinc-900 text-white border border-zinc-800 rounded-xl px-3 py-1.5 text-xs font-bold shadow-md focus:outline-none focus:border-zinc-700 cursor-pointer">
                <option value="en" <%= currentLang === 'en' ? 'selected' : '' %>>English 🇬🇧</option>
                <option value="ar" <%= currentLang === 'ar' ? 'selected' : '' %>>العربية 🇪🇬</option>
            </select>
        </div>
    </div>
</div>
